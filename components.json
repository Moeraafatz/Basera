{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "new-york",
  "rsc": true,
  "tsx": true,
  "tailwind": {
    "config": "",
    "css": "src/app/globals.css",
    "baseColor": "zinc",
    "alias": {
      "@/*": ["./src/*"]
    }
  },
  "iconLibrary": "lucide",
  "components": {
    "@/components/ui/*": {
      "default": {
        "social": {
          "twitter": "https://x.com",
          "github": "https://github.com/shadcn"
        }
      }
    }
  },
  "aliases": {
    "components": "@/components",
    "utils": "@/lib/utils",
    "ui": "@/components/ui",
    "lib": "@/lib",
    "hooks": "@/hooks"
  }
}
